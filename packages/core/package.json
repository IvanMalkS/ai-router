{
  "name": "@van1s1mys/ai-router",
  "version": "1.2.1",
  "description": "Semantic search routing using AI embeddings — find the best route by meaning, not keywords",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "keywords": [
    "router",
    "ai",
    "semantic-search",
    "embeddings",
    "spa",
    "navigation"
  ],
  "homepage": "https://ivanmalks.github.io/ai-router/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IvanMalkS/ai-router.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/IvanMalkS/ai-router/issues"
  },
  "license": "MIT",
  "devDependencies": {
    "esbuild": "^0.27.0"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@orama/orama": "^3.1.18"
  }
}
